# Plugin Pique — Variaveis de ambiente obrigatorias
# Copie este arquivo como referencia e configure no seu ambiente (shell profile, .env, etc.)

# === OBRIGATORIO PRA TODOS ===

# ClickUp: API key pessoal (cada membro tem a sua)
# Obter em: ClickUp > Settings > Apps > API Token
PIQUE_CLICKUP_API_KEY=pk_XXXXX

# ClickUp: Workspace ID (compartilhado — mesmo pra todos)
PIQUE_CLICKUP_TEAM_ID=36702200

# === OBRIGATORIO PRA SOCIAL SKILLS ===

# Apify: Token da conta empresa (scraping Instagram)
# Obter em: apify.com > Settings > Integrations > API Tokens
PIQUE_APIFY_TOKEN=apify_api_XXXXX

# === OPCIONAL ===

# Google Calendar + Gmail: configurados via Claude AI connectors (OAuth por usuario)
# Nao precisa de env var — autentica pelo Claude Desktop/Code
