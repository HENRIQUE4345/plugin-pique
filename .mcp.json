{
  "mcpServers": {
    "clickup": {
      "command": "npx",
      "args": ["-y", "@taazkareem/clickup-mcp-server@latest"],
      "env": {
        "CLICKUP_API_KEY": "${PIQUE_CLICKUP_API_KEY}",
        "CLICKUP_TEAM_ID": "${PIQUE_CLICKUP_TEAM_ID}"
      }
    },
    "apify": {
      "command": "npx",
      "args": ["-y", "@apify/actors-mcp-server@latest"],
      "env": {
        "APIFY_TOKEN": "${PIQUE_APIFY_TOKEN}"
      }
    }
  }
}
