{
  "name": "pique-clickup-mcp",
  "version": "0.1.0",
  "description": "MCP custom enxuto para gestao do ClickUp da Pique Digital. Substitui o MCP oficial com defaults embutidos, operacoes compostas e cache de hierarquia.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "pique-clickup-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
